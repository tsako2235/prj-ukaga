{
  "name": "ukaga",
  "version": "0.1.0",
  "description": "伺か風 Live2D デスクトップマスコット",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.yml",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "dist:linux": "npm run build && electron-builder --linux --config electron-builder.yml",
    "pack": "npm run build && electron-builder --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@pixi/core": "^7.4.3",
    "@pixi/display": "^7.4.3",
    "electron-store": "^8.2.0",
    "pixi-live2d-display": "0.5.0-beta",
    "pixi.js": "^7.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  },
  "author": "ukaga"
}
